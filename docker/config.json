{
  "supervisionUrls": ["wss://ocpp-ws-server.onrender.com"],
  "supervisionUrlDistribution": "round-robin",
  "log": {
    "file": "/dev/stdout",
    "errorFile": "/dev/stderr",
    "console": false,
    "rotate": false
  },
  "worker": {
    "processType": "workerSet",
    "elementsPerWorker": 1,
    "poolMinSize": 4,
    "poolMaxSize": 16
  },
  "performanceStorage": {
    "enabled": true,
    "type": "none"
  },
  "uiServer": {
    "enabled": true,
    "type": "ws",
    "options": {
      "host": "0.0.0.0",
      "port": 10000
    },
    "authentication": {
      "enabled": true,
      "type": "protocol-basic-auth",
      "username": "admin",
      "password": "admin"
    }
  },
  "stationTemplateUrls": [
    { "file": "virtual-simple-atg.station-template.json", "numberOfStations": 10 },
    { "file": "virtual-simple.station-template.json", "numberOfStations": 0 },
    { "file": "virtual.station-template.json", "numberOfStations": 0 },
    { "file": "keba.station-template.json", "numberOfStations": 0 },
    { "file": "schneider.station-template.json", "numberOfStations": 0 }
  ]
}